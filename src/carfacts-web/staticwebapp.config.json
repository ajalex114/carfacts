{
  "navigationFallback": {
    "rewrite": "/404.html",
    "exclude": [
      "/images/*",
      "/assets/*",
      "/feed/*",
      "*.{png,jpg,jpeg,gif,webp,svg,ico,css,js,woff,woff2,ttf,eot,xml,txt}"
    ]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  },
  "globalHeaders": {
    "X-Frame-Options": "SAMEORIGIN",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()",
    "Strict-Transport-Security": "max-age=31536000; includeSubDomains"
  },
  "mimeTypes": {
    ".xml": "application/xml",
    ".txt": "text/plain"
  }
}
